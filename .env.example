# Copy this to .env and fill in your keys

# Apollo.io — https://app.apollo.io/#/settings/integrations/api (free tier available)
APOLLO_API_KEY=your_apollo_api_key_here

# Anthropic (Claude) — https://console.anthropic.com/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Tracxn (optional supplement) — https://tracxn.com/api
TRACXN_API_KEY=your_tracxn_api_key_here

# Path to Google OAuth credentials JSON
# Download from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GMAIL_CREDENTIALS_FILE=credentials.json
